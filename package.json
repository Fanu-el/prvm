{
  "name": "@fanu-el/prvm",
  "version": "0.1.0",
  "description": "Prompt Version Manager — track, test, and manage LLM prompt versions",
  "license": "MIT",
  "author": "Fanuel Amare",
  "repository": {
    "type": "git",
    "url": "https://github.com/fanu-el/prvm"
  },
  "keywords": [
    "llm",
    "prompt",
    "versioning",
    "cli",
    "ai"
  ],
  "bin": {
    "prvm": "./dist/index.js"
  },
  "scripts": {
    "build": "rimraf dist && tsup src/index.ts --format cjs --dts",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "openai": "^4.52.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "inquirer": "^14.0.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "jest": "^30.4.2",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
